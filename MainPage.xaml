<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="IessApp.MainPage">

    <ScrollView>
        <VerticalStackLayout
            Padding="30,50,30,30"
            Spacing="20">
            
            <Label
                Text="Cálculo de Aporte IESS"
                FontSize="24"
                FontAttributes="Bold"
                HorizontalOptions="Center" />

            <Entry
                x:Name="NombreEntry"
                Placeholder="Nombre" />

            <Entry
                x:Name="ApellidoEntry"
                Placeholder="Apellido" />

            <Entry
                x:Name="EdadEntry"
                Placeholder="Edad"
                Keyboard="Numeric" />

            <Entry
                x:Name="SalarioEntry"
                Placeholder="Salario"
                Keyboard="Numeric" />

            <Button
                Text="Calcular"
                Clicked="OnCalcularClicked"
                HorizontalOptions="Fill" />
        </VerticalStackLayout>
    </ScrollView>

</ContentPage>
